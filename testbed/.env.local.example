# TaskHub Local Development Environment
# Copy to .env.local and fill in values (or let `vagrant provision` auto-generate).

# --- App Database ---
POSTGRES_PASSWORD=changeme
POSTGRES_DB=taskhub
POSTGRES_USER=taskhub

# --- Backend secrets (must be >= 32 chars each) ---
JWT_ACCESS_SECRET=changeme_replace_with_a_long_random_string_32+
JWT_REFRESH_SECRET=changeme_replace_with_a_different_long_random_32+
# 64 lowercase hex chars (32 bytes). Encrypts LDAP/SCIM/2FA/webhook secrets.
MASTER_KEY=changeme

# --- Seed admin (created on first boot; password is upserted, change in prod) ---
SEED_ADMIN_EMAIL=admin@taskhub.local
SEED_ADMIN_PASSWORD=admin

# --- Optional: richer demo dataset (4 teams, ~180 tasks). Set to 1 to enable. ---
SEED_IT_DEMO=
