{
  "name": "taskhub-frontend",
  "version": "1.80.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "sync-manual": "node ./scripts/copy-manual.mjs",
    "prebuild": "node ./scripts/copy-manual.mjs && node ./scripts/generate-pwa-icons.mjs",
    "predev": "node ./scripts/copy-manual.mjs && node ./scripts/generate-pwa-icons.mjs",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vitest run"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@tanstack/react-query": "^5.51.0",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^6.24.1",
    "recharts": "^2.15.4",
    "remark-gfm": "^4.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.4",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.6.0",
    "postcss": "^8.4.39",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.3.3",
    "vite-plugin-pwa": "^0.21.1",
    "vitest": "^2.1.9"
  }
}
