# Local dev .env for the backend. Copy to .env (gitignored).
NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://taskhub:taskhub@localhost:5432/taskhub?schema=public
REDIS_URL=redis://localhost:6379

# Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=dev_only_replace_me_with_a_long_random_string
JWT_REFRESH_SECRET=dev_only_replace_me_with_a_different_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

COOKIE_DOMAIN=
COOKIE_SECURE=false

CORS_ORIGINS=http://localhost:5173

UPLOAD_MAX_BYTES=10485760
UPLOAD_DIR=./uploads

AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# --- SMTP (v1.14) ---
# Leave SMTP_HOST blank to disable outbound mail. The app keeps working —
# verification + password-reset tokens still surface in non-prod responses
# as devVerifyToken / devResetToken, and TASK_DUE notifications continue to
# appear in the in-app bell. Set SMTP_HOST to enable real delivery.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Required when SMTP_HOST is set. The mailer throws on first send if missing.
SMTP_FROM=TaskHub <no-reply@taskhub.local>
# Public origin used when building links in emails. Falls back to the first
# CORS_ORIGINS entry if unset.
PUBLIC_APP_URL=http://localhost:5173

# --- Update check (v1.16) ---
# Opt-in check against the canonical TaskHub GitHub repo's latest release.
# Disabled by default — self-hosted installs shouldn't make outbound calls
# without operator consent. Admin-only endpoint at /api/admin/update-check.
UPDATE_CHECK_ENABLED=false
UPDATE_CHECK_CACHE_HOURS=6
