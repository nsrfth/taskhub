# dependencies
node_modules/
.pnpm-store/

# build output
dist/
build/
*.tsbuildinfo

# env
.env
.env.local
.env.*.local
.env.bak.*

# Leftover from a prior history-rewrite session — local-only safety copy
.git.backup-before-rewrite/

# Ephemeral commit-message scratch files used by docker-run-git pipelines.
commitmsg.tmp
.commitmsg.tmp

# logs
*.log
npm-debug.log*
pnpm-debug.log*

# editor
.vscode/
.idea/
*.swp
.DS_Store

# uploads (mounted volume)
backend/uploads/*
!backend/uploads/.gitkeep

# test / coverage
coverage/
.nyc_output/

# prisma
backend/prisma/*.db

# Claude Code session metadata (user-local, never relevant to others)
.claude/

# v1.10.1 + v1.13.0: USER_MANUAL{,.fa}.md are canonical at the repo root;
# the frontend copies are auto-synced by `npm run sync-manual` (also runs
# pre-build / pre-dev).
frontend/public/USER_MANUAL.md
frontend/public/USER_MANUAL.fa.md
