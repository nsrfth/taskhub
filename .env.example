# Root .env consumed by docker-compose. Copy to .env and edit before `docker compose up`.
# Never commit the real .env.

# --- Postgres ---
POSTGRES_USER=taskhub
POSTGRES_PASSWORD=change_me_please
POSTGRES_DB=taskhub

# --- Backend ---
NODE_ENV=production
PORT=4000
# Connection string the backend container uses to reach postgres on the compose network.
DATABASE_URL=postgresql://taskhub:change_me_please@postgres:5432/taskhub?schema=public
REDIS_URL=redis://redis:6379

# JWT secrets must be long random strings. Generate with: openssl rand -base64 48
JWT_ACCESS_SECRET=replace_with_random_48_byte_secret
JWT_REFRESH_SECRET=replace_with_different_random_48_byte_secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Cookie config
COOKIE_DOMAIN=
COOKIE_SECURE=true

# CORS: comma-separated allowlist of origins. Use "*" only in dev.
CORS_ORIGINS=https://taskhub.example.com

# Upload limits
UPLOAD_MAX_BYTES=10485760
UPLOAD_DIR=/app/uploads

# Rate limits
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW=1 minute

# --- SMTP (v1.14) ---
# Leave SMTP_HOST blank to disable outbound email entirely. With SMTP off,
# verification + password-reset tokens are still issued (and surfaced as
# devVerifyToken / devResetToken in non-prod) and the in-app notification
# bell still fires for TASK_DUE — only the email leg is skipped.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Required when SMTP_HOST is set. Anything from the address spec is accepted
# ("TaskHub <no-reply@example.com>", or a bare "no-reply@example.com").
SMTP_FROM=TaskHub <no-reply@example.com>
# Public origin used when building links in emails. Falls back to the first
# CORS_ORIGINS entry if unset.
PUBLIC_APP_URL=https://taskhub.example.com

# --- Build identity (About page + update check) ---
# Set to match CHANGELOG.md (e.g. v1.44.1). Empty → About shows "dev".
TASKHUB_VERSION=v1.77.0
TASKHUB_BUILD_TIME=

# v1.49: hidden system team manager. Defaults to admin@taskhub.local.
# Set to your seeded admin email if different (must match the User row).
SYSTEM_USER_EMAIL=admin@taskhub.local

# --- Update check (v1.16) ---
# Opt-in check against the canonical TaskHub GitHub repo's latest release.
# Disabled by default — self-hosted installs shouldn't make outbound calls
# without operator consent. Surfaces as a quiet "Update available" badge on
# the /about page for global admins. Admin-only endpoint, cached 6 hours.
UPDATE_CHECK_ENABLED=false
UPDATE_CHECK_CACHE_HOURS=6

# --- Automatic backups (v1.27) ---
# Off by default. Set BACKUP_ENABLED=true on exactly ONE backend instance to
# let the scheduler run pg_dump on the cadence configured in
# Settings → Backups. Period (hours) + retention (count) are admin-set in
# the UI; this flag only opts the in-process scheduler in. Files live on
# the backups_data named volume (BACKUP_DIR inside the container).
BACKUP_ENABLED=false
BACKUP_DIR=/app/backups
# Granularity at which the scheduler wakes up to check whether a new dump is
# due. Smaller than the smallest allowed interval (1h).
BACKUP_CHECK_INTERVAL_MIN=15

# --- In-app self-upgrade (v1.22) ---
# Disabled by default. To enable:
#   1. Generate a long random token (e.g. openssl rand -base64 48) and set
#      both UPDATER_TOKEN and the matching value in the updater sidecar.
#   2. Bring the `upgrade` profile up:
#        docker compose --profile upgrade up -d updater
#   3. Set UPDATER_URL = http://updater:9000 below.
# The updater holds the host docker socket — read UPGRADE.md before
# enabling on a production host.
UPDATER_URL=
UPDATER_TOKEN=

# --- Frontend (build-time) ---
# Public origin browsers will hit. Caddy reverse-proxies /api to backend.
VITE_API_BASE_URL=/api

# --- Caddy ---
# Public hostname; used in Caddyfile via {$SITE_HOST}. Leave as :80 for local-only HTTP.
SITE_HOST=:80
# Set to an admin email to enable Let's Encrypt automatic HTTPS for a real domain.
ACME_EMAIL=
