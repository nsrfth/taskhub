// Prisma schema for TaskHub.
// See ARCHITECTURE.md for the rationale behind the GlobalRole/TeamRole split,
// the denormalized Task.teamId, and hashed refresh tokens.

generator client {
  provider      = "prisma-client-js"
  // "native" covers whichever host runs `prisma migrate dev` (Windows/macOS/glibc Linux).
  // "linux-musl-openssl-3.0.x" is required for the Alpine runtime image — without it
  // the engine defaults to the openssl-1.1.x binary, which Alpine 3.18+ doesn't ship.
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum GlobalRole {
  ADMIN
  MEMBER
}

enum TeamRole {
  MANAGER
  MEMBER
}

enum ProjectStatus {
  ACTIVE
  ARCHIVED
  ON_HOLD
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum NotifyType {
  TASK_ASSIGNED
  TASK_COMMENT
  TASK_DUE
  MENTION
  TASK_STATUS
  // v1.29: a task you depended on completed and you now have zero
  // incomplete blockers. Recipient = assignee + responsible of the dependent.
  TASK_UNBLOCKED
  // v1.51: user group invitation for cross-team project access.
  GROUP_INVITE
}

enum GroupAccessLevel {
  FULL
  READONLY
}

// v1.59: budget currency codes. IRR displays with 0 decimal places;
// EUR/USD with 2. Storage stays Decimal(18,2) for all currencies.
enum Currency {
  IRR
  EUR
  USD
}

// v1.58: custom field types for team-scoped task metadata.
enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  SINGLE_SELECT
  MULTI_SELECT
  CHECKBOX
  PERSON
}

enum GroupInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

// v1.29: relationship kind on a TaskDependency edge.
//   FINISH_TO_START — the standard "blocker" edge: the dependent task
//     cannot move to IN_PROGRESS/DONE while the dependsOn task is incomplete
//     (gated by the tasks.dependencyEnforcement InstanceSetting).
//   RELATES_TO     — informational link only; status guard ignores it.
enum DependencyType {
  FINISH_TO_START
  RELATES_TO
  // v1.83: scheduling types enforced via status rules (not dates).
  // SS: B can't START until A has started. FF: B can't FINISH until A has.
  START_TO_START
  FINISH_TO_FINISH
}

enum DirectoryKind {
  LDAP
  // SCIM placeholder for Phase 2B — kept in the same enum so a SCIM directory
  // can reuse the same Directory row + group mappings.
  SCIM
}

// How the user signs in. LOCAL = argon2 password in TaskHub; LDAP = directory
// bind; SCIM = provisioned via SCIM (no password login).
enum AuthSource {
  LOCAL
  LDAP
  SCIM
}

// v1.10: per-user display calendar. Affects every place the frontend renders
// a calendar date or timestamp. Default SHAMSI matches the pre-v1.10
// behaviour (TaskHub is Persian-leaning by default); switching to GREGORIAN
// is a one-checkbox change on Settings → Preferences.
enum CalendarPreference {
  SHAMSI
  GREGORIAN
}

// v1.13: per-user theme. LIGHT default — pre-v1.13 the SPA shipped
// light-only, so existing users see no surprise.
enum ThemePreference {
  LIGHT
  DARK
  SYSTEM
  MIDNIGHT
  SOLARIZED
  HIGH_CONTRAST
  NORD
}

enum HolidaySource {
  MANUAL
  IMPORT
  SYNC
}

// v1.13: per-user UI language. EN is the canonical key source; FA covers
// the most-visible surfaces in this release. Strings without an FA entry
// fall back to EN.
enum LanguagePreference {
  EN
  FA
}

enum TimeFormat {
  H12
  H24
}

// External identity provider. Phase 2A handles LDAP; SCIM in 2B reuses this.
// One Directory binds many Users (via User.directoryId/externalId).
model Directory {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  kind        DirectoryKind @default(LDAP)
  // LDAP connection details — ignored for non-LDAP kinds.
  host        String?
  port        Int?
  useTLS      Boolean       @default(true)
  // When true, LDAPS / STARTTLS skips TLS certificate chain verification.
  // Use only with internal AD CAs; prefer installing the CA in the container.
  tlsInsecure Boolean       @default(false)
  bindDN      String?
  // Bind password ciphertext (AES-256-GCM via lib/crypto). NEVER surface in
  // any API response — Zod response schemas must not include this field.
  bindPasswordEnc String?
  baseDN      String?
  userFilter  String?  // e.g. "(objectClass=person)"
  groupFilter String?  // e.g. "(objectClass=groupOfNames)"
  // Attribute names — different LDAPs use different conventions.
  userIdAttr        String  @default("uid")   // AD users typically use sAMAccountName.
  emailAttr         String  @default("mail")
  nameAttr          String  @default("cn")
  groupMemberAttr   String  @default("member")
  // Just-in-time provisioning: when true, a successful LDAP bind creates a
  // local User row if one doesn't exist yet.
  allowJIT          Boolean @default(true)
  // Roll group memberships into TaskHub roles on every login.
  syncRolesFromGroups Boolean @default(false)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  users         User[]                  @relation("UserDirectory")
  teams         Team[]                  @relation("TeamDirectory")
  groupMappings DirectoryGroupMapping[]
  scimCredential ScimCredential?
}

// One-time 2FA recovery code. The raw code is shown to the user exactly once
// at generation; only the sha256 hash is persisted. `usedAt` survives the
// row to make burn-on-first-use observable in audit.
model RecoveryCode {
  id        String    @id @default(cuid())
  userId    String
  codeHash  String    @unique
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Bearer credential an external IdP uses to push SCIM 2.0 provisioning calls
// at this Directory. One credential per Directory — re-generation overwrites
// the row. `tokenHash` is sha256(rawToken); the raw token is shown to the
// admin exactly once at generation time and never persisted.
model ScimCredential {
  id          String    @id @default(cuid())
  directoryId String    @unique
  tokenHash   String    @unique
  // Human-readable label shown in the UI (e.g. "Okta production").
  name        String
  createdAt   DateTime  @default(now())
  lastUsedAt  DateTime?
  revokedAt   DateTime?
  directory   Directory @relation(fields: [directoryId], references: [id], onDelete: Cascade)

  @@index([directoryId])
}

// External group DN → TaskHub role. Phase 2A supports global roles + team-
// scoped manager/member assignment. teamId is nullable: when set, the
// mapping grants membership in that specific team; when null, it grants the
// listed globalRole instance-wide.
model DirectoryGroupMapping {
  id              String     @id @default(cuid())
  directoryId     String
  externalGroupDn String
  globalRole      GlobalRole?
  teamId          String?
  teamRole        TeamRole?
  // v1.30.6 (S-6 / S-7): explicit custom-role pointer. When set, the
  // LDAP / SCIM provisioning path stamps THIS role onto the
  // TeamMembership it creates. When null, the path falls back to the
  // team's system Manager / Member role matching `teamRole`. SetNull
  // on Role delete so removing a role just degrades the mapping to
  // "use system Member" — doesn't cascade-delete the mapping itself.
  roleId          String?
  role            Role?      @relation(fields: [roleId], references: [id], onDelete: SetNull)

  directory       Directory  @relation(fields: [directoryId], references: [id], onDelete: Cascade)

  @@unique([directoryId, externalGroupDn])
  @@index([directoryId])
  @@index([roleId])
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  // Nullable as of v1.4 — LDAP-managed users have no local password. Local
  // users continue to set this at register time. authService gates which
  // flow to run based on directoryId.
  passwordHash    String?
  name            String
  globalRole      GlobalRole @default(MEMBER)
  // Set when the user is owned by an external directory. null = local user.
  directoryId     String?
  // External stable identifier (LDAP DN, SCIM externalId). Unique together
  // with directoryId so multiple directories can use overlapping IDs.
  externalId      String?
  // Explicit auth backend — backfilled from directoryId + Directory.kind for
  // existing rows. LOCAL users have directoryId=null.
  authSource      AuthSource @default(LOCAL)
  // LDAP profile fields (synced on login / admin refresh). Null for LOCAL users.
  ldapUsername    String?
  userPrincipalName String?
  department      String?
  jobTitle        String?
  managerName     String?
  ldapSyncedAt    DateTime?
  // Local-password policy tracking (ignored for LDAP/SCIM users).
  passwordChangedAt   DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Set when the user is soft-disabled. Login + refresh both reject when
  // this is non-null. SCIM deprovision (PATCH active=false) sets this and
  // revokes outstanding refresh tokens; reprovision (active=true) clears it.
  disabledAt      DateTime?
  // v1.49: built-in system identity (admin@taskhub.local). Hidden from all
  // user-facing lists; auto-assigned as manager on every team.
  isSystemUser    Boolean    @default(false)
  // TOTP 2FA (Phase 2C). totpSecretEnc holds the AES-256-GCM ciphertext of
  // the shared secret; totpEnabled flips true only after the user confirms
  // a code during setup. Both clear on disable.
  totpSecretEnc   String?
  totpEnabled     Boolean    @default(false)
  // v1.10: display calendar preference. Read by the frontend at login,
  // mirrored into localStorage, and applied to every date/timestamp the
  // UI renders + the date pickers.
  calendarPreference CalendarPreference @default(SHAMSI)
  // v1.13: per-user theme (LIGHT default) + UI language (EN default).
  // Mirrored to localStorage on login; the SPA applies them via
  // <html class="dark"> and <html dir="rtl" lang="fa"> respectively.
  themePreference    ThemePreference    @default(LIGHT)
  languagePreference LanguagePreference @default(EN)
  // v1.63: timestamp display — IANA zone for category-(b) instants only;
  // calendar dates (dueDate, etc.) stay UTC-midnight zone-neutral.
  timeZone           String?
  timeFormat         TimeFormat         @default(H24)
  dualCalendar       Boolean            @default(false)
  // v1.65: hours before dueDate to emit TASK_DUE (assignee preference).
  reminderLeadHours  Int?               @default(24)
  emailVerifiedAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  directory       Directory? @relation("UserDirectory", fields: [directoryId], references: [id], onDelete: SetNull)

  @@unique([directoryId, externalId])
  @@index([directoryId])

  memberships    TeamMembership[]
  ownedProjects  Project[]        @relation("ProjectOwner")
  accountableForProjects Project[] @relation("ProjectAccountable")
  assignedTasks  Task[]           @relation("TaskAssignee")
  createdTasks   Task[]           @relation("TaskCreator")
  responsibleForTasks    Task[]    @relation("TaskResponsible")
  responsibleForSubtasks Subtask[] @relation("SubtaskResponsible")
  // v1.42: Subtask assignee — distinct from responsible (RACI). Anyone
  // with project access can change this; SetNull on user delete.
  assignedSubtasks      Subtask[] @relation("SubtaskAssignee")
  deletedTasks    Task[]    @relation("TaskDeletedBy")
  deletedComments Comment[] @relation("CommentDeletedBy")
  comments       Comment[]
  activities     Activity[]
  notifications  Notification[]
  refreshTokens      RefreshToken[]
  passwordResets     PasswordReset[]
  emailVerifications EmailVerification[]
  uploads            Attachment[]
  recoveryCodes      RecoveryCode[]
  apiTokens          ApiToken[]
  passwordHistory    PasswordHistory[]
  projectBuckets     UserProjectBucket[]
  userGroupMembers   UserGroupMember[]
  groupInvitesSent   UserGroupMember[] @relation("GroupInvitesSent")
  customFieldValues  CustomFieldValue[] @relation("CustomFieldPerson")
  holidaysCreated    Holiday[]          @relation("HolidayCreatedBy")
  ownedDashboards    Dashboard[]        @relation("DashboardOwner")
  createdIntakeForms IntakeForm[]       @relation("IntakeFormCreator")
  // v1.86: per-project full-edit delegations granted to / by this user.
  projectEditDelegations ProjectEditDelegate[] @relation("ProjectEditDelegateUser")
  projectEditDelegatesGranted ProjectEditDelegate[] @relation("ProjectEditDelegateGrantedBy")

  @@index([email])
}

// v1.45: per-user project organization buckets on the Projects page.
// Personal views only — no effect on project data or permissions.
model UserProjectBucket {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  description String?
  color       String?
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items UserProjectBucketItem[]

  @@unique([userId, name])
  @@index([userId, position])
}

model UserProjectBucketItem {
  id        String   @id @default(cuid())
  bucketId  String
  bucket    UserProjectBucket @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  userId    String
  projectId String
  position  Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([bucketId, projectId])
  @@index([bucketId, position])
  @@index([userId, projectId])
}

// Previous password hashes for local users — enforces password history policy.
model PasswordHistory {
  id           String   @id @default(cuid())
  userId       String
  passwordHash String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// Security and server configuration audit trail (distinct from task Activity).
model SecurityAuditEvent {
  id        String   @id @default(cuid())
  kind      String
  actorId   String?
  details   Json
  createdAt DateTime @default(now())

  @@index([kind, createdAt])
  @@index([createdAt])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  // Store SHA-256 of the raw token; a DB leak should not yield usable sessions.
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  // v1.30.5 (S-4): rotation chains share a familyId. On first issue
  // (login / register / 2FA-login) familyId = self.id. On rotation the
  // newly issued row inherits the presented token's familyId. When a
  // refresh sees an ALREADY-revoked token (replay of a token already
  // rotated away), the whole family is revoked — that's the canonical
  // response to detected token theft.
  familyId  String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailVerification {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Team {
  id            String           @id @default(cuid())
  name          String
  slug          String           @unique
  // When set, the team's membership is synthesized from LDAP/SCIM group
  // mappings rather than manually managed. Manager-driven invites are
  // disabled in the UI for directory-managed teams.
  directoryId   String?
  // v1.12: per-team accent colour shown on kanban cards + calendar views.
  // Hex like "#3b82f6"; null = default slate. Admins / team managers set it.
  color           String?
  // v1.59: pre-fills budget currency on newly created projects (editable per project).
  defaultCurrency Currency         @default(IRR)
  createdAt       DateTime         @default(now())
  memberships   TeamMembership[]
  projects      Project[]
  labels        Label[]
  roles         Role[]
  notifications Notification[]
  activities    Activity[]       @relation("TeamActivity")
  webhooks      Webhook[]
  userGroups    UserGroup[]
  customFields  CustomFieldDefinition[]
  automationRules AutomationRule[]
  dashboards    Dashboard[]
  intakeForms   IntakeForm[]
  directory     Directory?       @relation("TeamDirectory", fields: [directoryId], references: [id], onDelete: SetNull)

  @@index([directoryId])
}

model TeamMembership {
  id       String   @id @default(cuid())
  userId   String
  teamId   String
  // v1.23: legacy enum, kept as fallback for one release while migration
  // backfills the new roleId. v1.24 drops this column. Service layer reads
  // roleId first; falls back to this field when roleId is null.
  role     TeamRole @default(MEMBER)
  // v1.23: custom role assignment. Nullable initially so the migration can
  // create the column, backfill, then later releases enforce NOT NULL.
  roleId   String?
  joinedAt DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  customRole Role?  @relation("MembershipRole", fields: [roleId], references: [id], onDelete: SetNull)

  @@unique([userId, teamId])
  @@index([teamId])
  @@index([roleId])
}

// v1.23: per-team custom role. Two seed roles per team ("Manager", "Member")
// land with `isSystem = true` — editable but undeletable. Admins create
// additional roles freely.
model Role {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  permissions RolePermission[]
  memberships TeamMembership[] @relation("MembershipRole")
  // v1.30.6 (S-6 / S-7): directory mappings pointing at this custom role.
  directoryMappings DirectoryGroupMapping[]

  @@unique([teamId, name])
  @@index([teamId])
}

// v1.23: role × permission junction. The `permission` field stores one of
// the constants from lib/permissions.ts; the service layer rejects anything
// else on write. Permissions themselves are NOT a database table — they're
// bound to code paths.
model RolePermission {
  roleId     String
  permission String

  role       Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permission])
}

model Project {
  id            String        @id @default(cuid())
  teamId        String
  ownerId       String?
  // v1.17: "Accountable" in RACI terms — the person on the hook for this
  // project's outcomes. Distinct from the owner (often the manager who
  // maintains it). Nullable so the field stays optional; SetNull on user
  // delete so we don't cascade-nuke projects.
  accountableId String?
  name          String
  description   String?
  status        ProjectStatus @default(ACTIVE)
  // v1.41: optional budget fields. DECIMAL(18,2): 16 digits before the
  // decimal point + 2 after (currency-grade precision in any unit).
  // Non-negative is enforced by DB CHECK + Zod; nullable so existing
  // projects stay valid without backfill.
  plannedBudget  Decimal?  @db.Decimal(18, 2)
  // v1.59: currency label for budget amounts (no conversion). Task budgets
  // inherit this currency — tasks do not store their own currency column.
  budgetCurrency Currency    @default(IRR)
  // v1.72: optional project schedule window (UTC-midnight calendar dates).
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime  @default(now())
  updatedAt     DateTime      @updatedAt
  team          Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  // ownerId is nullable + SetNull so admins can delete a user without
  // cascading the deletion to every project they own. The project then shows
  // "owner: (deleted user)" in the UI until a manager reassigns it.
  owner         User?         @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  accountable   User?         @relation("ProjectAccountable", fields: [accountableId], references: [id], onDelete: SetNull)
  tasks         Task[]
  groupGrants   ProjectGroupGrant[]
  editDelegates ProjectEditDelegate[]
  intakeForms   IntakeForm[]
  labels        ProjectLabel[]

  // v1.30: tsvector for full-text search. See Task.searchVector for
  // rationale + lifecycle (managed by raw SQL, never read via Prisma).
  // Unsupported(...) auto-excludes the column from the Prisma client; the
  // SearchService talks to it via $queryRaw only.
  searchVector Unsupported("tsvector")?

  @@index([teamId, status])
  @@index([teamId, startDate])
  @@index([ownerId])
  @@index([accountableId])
}

// v1.50 / v1.51: team-scoped user groups for granting project access without
// changing project ownership. v1.51 adds cross-team invites + access levels.
model UserGroup {
  id          String   @id @default(cuid())
  teamId      String
  name        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team     Team                @relation(fields: [teamId], references: [id], onDelete: Cascade)
  members  UserGroupMember[]
  grants   ProjectGroupGrant[]

  @@unique([teamId, name])
  @@index([teamId])
}

model UserGroupMember {
  id          String            @id @default(cuid())
  groupId     String
  userId      String
  accessLevel GroupAccessLevel  @default(FULL)
  status      GroupInviteStatus @default(ACCEPTED)
  invitedById String?
  invitedAt   DateTime          @default(now())
  respondedAt DateTime?
  external    Boolean           @default(false)

  group     UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User?     @relation("GroupInvitesSent", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([groupId, userId])
  @@index([userId, status])
  @@index([groupId])
}

model ProjectGroupGrant {
  projectId String
  groupId   String
  grantedAt DateTime @default(now())

  project Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  group   UserGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@id([projectId, groupId])
  @@index([groupId])
}

// v1.86: per-project "full-edit" delegation. The project owner (or a global
// ADMIN) names users who may edit ALL task/subtask fields on this project —
// crucially the manager-only date fields and the task.change_responsible-gated
// field — for THIS project only. Deliberately separate from project access
// (resolveProjectAccess) and group grants: WRITE/FULL must NOT silently bypass
// those field-level restrictions, so the elevation is its own explicit record.
model ProjectEditDelegate {
  projectId   String
  userId      String
  grantedById String?
  grantedAt   DateTime @default(now())

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User    @relation("ProjectEditDelegateUser", fields: [userId], references: [id], onDelete: Cascade)
  grantedBy User?   @relation("ProjectEditDelegateGrantedBy", fields: [grantedById], references: [id], onDelete: SetNull)

  @@id([projectId, userId])
  @@index([userId])
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  // 3-month cadence — useful for OKR/QBR rituals. Equivalent to MONTHLY
  // with interval=3 mathematically, but a first-class enum value lets the
  // UI show "Quarterly" instead of forcing admins to interpret 'every 3
  // months'.
  QUARTERLY
  YEARLY
}

// Recurrence rule attached to a source Task. When the scheduler ticks past
// `nextRunAt`, it spawns a fresh Task with `spawnedFromTemplateId` pointing
// back here. One template per task (`sourceTaskId` is unique). Disable
// without deleting by flipping `active`.
model TaskTemplate {
  id              String              @id @default(cuid())
  sourceTaskId    String              @unique
  frequency       RecurrenceFrequency
  interval        Int                 @default(1)
  // Optional weekday filter — only meaningful for WEEKLY. 0 = Sunday … 6 = Saturday.
  byWeekday       Int[]
  // First eligible spawn date — UTC midnight per the v1.1.3 calendar-date rules.
  startsOn        DateTime
  // Optional cutoff (inclusive). After this, the rule stops spawning.
  endsOn          DateTime?
  // Optional cap on total spawns. Null = no cap.
  maxCount        Int?
  // Offsets applied to the spawned Task: spawn date + N days = dueDate /
  // plannedDate. Null = don't copy that date field at all.
  dueOffsetDays     Int?
  plannedOffsetDays Int?
  // Next time the scheduler should consider this rule. Always UTC-midnight.
  nextRunAt       DateTime
  spawnedCount    Int                 @default(0)
  active          Boolean             @default(true)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  sourceTask      Task                @relation("TaskTemplateSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  spawnedTasks    Task[]              @relation("TaskSpawnedFrom")

  @@index([active, nextRunAt])
}

model Task {
  id          String       @id @default(cuid())
  projectId   String
  // Denormalized for tenant scoping; every query filters by teamId.
  teamId      String
  // creatorId is nullable + SetNull so a deleted user's tasks remain.
  // The frontend renders "(deleted user)" wherever the creator name appears.
  creatorId   String?
  assigneeId  String?
  // v1.19: "Responsible" — the person actually doing the work.
  // Defaults to the creator on task creation. Only team MANAGERS / global
  // ADMINs can change this field after the fact. Nullable + SetNull so
  // user deletes don't cascade-kill tasks.
  responsibleId String?
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  // Hard deadline — "must be done by". Powers the TASK_DUE scheduler.
  dueDate     DateTime?
  // v1.37: "started on" date. Nullable, UTC midnight (same convention as
  // dueDate / plannedDate / completedAt). Subject to the v1.18
  // date-edit-restriction gate. NOT included in the calendar feed —
  // deferred. NOT used by any reminder or report — informational only
  // for now.
  startDate   DateTime?
  // Team's target completion date — "we plan to be done by". Used by the
  // timeliness report; doesn't trigger TASK_DUE notifications (those are for
  // the hard deadline only).
  plannedDate DateTime?
  // When the task was actually completed. Auto-filled on first transition to
  // status=DONE if not explicitly set; the member can also set it manually
  // (back-dating) regardless of status. Renamed from doneAt in v1.2.
  completedAt DateTime?
  // When a TASK_DUE notification was last emitted for this task — used by the
  // scheduler to avoid re-notifying every tick. Reset to null whenever dueDate
  // changes so the next due date triggers a fresh reminder.
  dueNotifiedAt DateTime?
  // Phase 4: spawned-by-recurrence linkage. spawnedForPeriod is the ISO date
  // of the period this task fulfils (e.g. "2026-05-23"); the unique pair
  // (templateId, period) prevents a double-spawn on retried scheduler ticks.
  spawnedFromTemplateId String?
  spawnedForPeriod      String?
  // v1.42: optional task-level budget fields. Same shape as v1.41 Project
  // budgets — DECIMAL(18,2), nullable, non-negative CHECK constraints.
  // The SPA computes utilization on the client as Actual / Planned * 100.
  plannedBudget Decimal?    @db.Decimal(18, 2)
  actualSpent   Decimal?    @db.Decimal(18, 2)
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  // v1.21: soft-delete. deletedAt = null means "live"; non-null means
  // "in trash". Every read query in the service layer filters on this.
  // Restoring sets it back to null; purging hard-deletes the row.
  deletedAt   DateTime?
  deletedById String?

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator     User?        @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: SetNull)
  assignee    User?        @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  responsible  User?        @relation("TaskResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  deletedBy   User?        @relation("TaskDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)
  subtasks    Subtask[]
  labels      TaskLabel[]
  attachments Attachment[]
  comments    Comment[]
  activities  Activity[]
  template          TaskTemplate? @relation("TaskTemplateSource")
  spawnedFromTemplate TaskTemplate? @relation("TaskSpawnedFrom", fields: [spawnedFromTemplateId], references: [id], onDelete: SetNull)
  // v1.29: dependency edges. `dependencies` are edges OUT of this task —
  // each row means "this task is blocked by row.dependsOn". `blockedTasks`
  // are edges IN — each row means "row.task is blocked by this task".
  // Both sides cascade on Task delete; the unique (taskId, dependsOnId)
  // constraint on TaskDependency prevents duplicate edges.
  dependencies TaskDependency[] @relation("TaskDependencyFrom")
  blockedTasks TaskDependency[] @relation("TaskDependencyTo")
  customFieldValues CustomFieldValue[]

  // v1.30: tsvector for full-text search. Managed by raw SQL — the column
  // is GENERATED ALWAYS AS STORED with a GIN index. Prisma never reads it
  // (it's @ignore-d on the client); the SearchService talks to it via
  // $queryRaw. Declared here so prisma migrate dev doesn't see drift.
  // Unsupported(...) auto-excludes the column from the Prisma client; the
  // SearchService talks to it via $queryRaw only.
  searchVector Unsupported("tsvector")?

  @@index([teamId, status])
  @@index([teamId, assigneeId])
  @@index([teamId, responsibleId])
  @@index([teamId, dueDate])
  @@index([teamId, deletedAt])
  // v1.30.10 (S-18): /reports/done + the CompletionTrend dashboard
  // chart filter on `completedAt >= now - Nd AND deletedAt IS NULL`.
  // Pre-v1.30.10 the planner sequentially scanned the team partition
  // on every render. This composite covers both predicates.
  @@index([teamId, completedAt])
  @@index([projectId, status, position])
  @@unique([spawnedFromTemplateId, spawnedForPeriod])
}

// v1.82: subtask progress status. Separate from TaskStatus (which is
// {TODO,IN_PROGRESS,REVIEW,DONE}) — subtasks use a different 5-state set with
// WAITING + DEFERRED and no REVIEW. `done` is KEPT and kept in sync with this
// (status DONE ⇔ done true) so the checkbox + "X of Y done" rollup keep working.
enum SubtaskStatus {
  NOT_STARTED
  IN_PROGRESS
  WAITING
  DEFERRED
  DONE
}

model Subtask {
  id           String    @id @default(cuid())
  taskId       String
  title        String
  done         Boolean   @default(false)
  // v1.82: progress status (5-state). Source of truth for completion; `done`
  // above is derived (DONE ⇔ true) by the service so legacy reads still work.
  status       SubtaskStatus @default(NOT_STARTED)
  // v1.19: Subtask responsible — same semantics as Task.responsibleId. Defaults
  // to creator on subtask creation; only team MANAGERS / global ADMINs can
  // change it. Nullable + SetNull.
  responsibleId String?
  // v1.42: Subtask assignee — distinct from responsible. Responsible is
  // RACI ("responsible for getting it done", manager-gated change);
  // assignee is the lighter-weight "who's working on this right now"
  // (anyone with project access can change). Mirrors Task.assigneeId.
  assigneeId   String?
  // v1.41: optional scheduling window. Anchored to UTC midnight (same
  // convention as Task.startDate / dueDate / plannedDate). Cross-field
  // rule "endDate >= startDate when both set" is enforced in the service
  // layer + DB CHECK constraint. Nullable so existing subtasks stay valid.
  startDate    DateTime?
  endDate      DateTime?
  position     Int       @default(0)
  task         Task    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  responsible   User?   @relation("SubtaskResponsible", fields: [responsibleId], references: [id], onDelete: SetNull)
  assignee     User?   @relation("SubtaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([taskId, status])
  @@index([responsibleId])
  @@index([assigneeId])
}

// v1.29: task dependency edges. `taskId` is the BLOCKED task; `dependsOnId`
// is the BLOCKER. Cycle prevention lives in the service layer (DFS reachability
// check before insert) — Postgres has no native cycle constraint and CHECK
// expressions can't traverse the table. Both FKs cascade so a deleted task
// tears its edges down with it.
model TaskDependency {
  id          String         @id @default(cuid())
  // Denormalized for tenant scoping, same as Task. Every read filters by
  // teamId so cross-tenant probes 404. Both endpoints of the edge must
  // share this teamId — enforced in the service layer.
  teamId      String
  taskId      String
  dependsOnId String
  type        DependencyType @default(FINISH_TO_START)
  createdAt   DateTime       @default(now())

  task      Task @relation("TaskDependencyFrom", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn Task @relation("TaskDependencyTo", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@index([teamId])
  @@index([dependsOnId])
}

model Label {
  id     String      @id @default(cuid())
  // v1.80: nullable. teamId = NULL → a GLOBAL "predefined" label: admin-managed,
  // visible and usable in EVERY team, read-only to members. Non-null → a team's
  // own user-defined label (unchanged behaviour). Uniqueness is enforced by two
  // PARTIAL unique indexes created in the migration — unique (teamId,name) for
  // team labels and unique (name) for globals — which Prisma can't express, so
  // @@unique is intentionally omitted here.
  teamId String?
  name   String
  color  String
  team   Team?       @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tasks  TaskLabel[]
  projects ProjectLabel[]
}

model ProjectLabel {
  projectId String
  labelId   String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  label     Label   @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([projectId, labelId])
  @@index([labelId])
}

model TaskLabel {
  taskId  String
  labelId String
  task    Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
  @@index([labelId])
}

// v1.58: team-scoped custom field definitions. Reusable across all projects
// in the team; per-task values live in CustomFieldValue. Project-scoped
// restriction is deferred to a future release.
model CustomFieldDefinition {
  id          String          @id @default(cuid())
  teamId      String
  name        String
  type        CustomFieldType
  description String?
  position    Int             @default(0)
  required    Boolean         @default(false)
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  options         CustomFieldOption[]
  values          CustomFieldValue[]
  intakeFormFields IntakeFormField[]

  @@unique([teamId, name])
  @@index([teamId, active])
}

model CustomFieldOption {
  id       String  @id @default(cuid())
  fieldId  String
  label    String
  color    String?
  position Int     @default(0)

  field      CustomFieldDefinition     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  selections CustomFieldValueOption[]

  @@unique([fieldId, label])
  @@index([fieldId])
}

// v1.58: typed per-task custom field values. One row per (field, task).
// Select values use CustomFieldValueOption join for filterable multi-select.
model CustomFieldValue {
  id          String    @id @default(cuid())
  fieldId     String
  taskId      String
  valueText   String?
  valueNumber Decimal?  @db.Decimal(18, 4)
  valueDate   DateTime?
  valueBool   Boolean?
  valueUserId String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  field      CustomFieldDefinition     @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  task       Task                      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  valueUser  User?                     @relation("CustomFieldPerson", fields: [valueUserId], references: [id], onDelete: SetNull)
  selections CustomFieldValueOption[]

  @@unique([fieldId, taskId])
  @@index([taskId])
  @@index([fieldId])
}

model CustomFieldValueOption {
  valueId  String
  optionId String

  value  CustomFieldValue  @relation(fields: [valueId], references: [id], onDelete: Cascade)
  option CustomFieldOption @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@id([valueId, optionId])
  @@index([optionId])
}

// v1.67: team-scoped configurable dashboards — saved widget collections.
model Dashboard {
  id          String   @id @default(cuid())
  teamId      String
  ownerId     String
  name        String
  description String?
  shared      Boolean  @default(false)
  position    Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  owner   User              @relation("DashboardOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  widgets DashboardWidget[]

  @@index([teamId])
  @@index([ownerId])
}

model DashboardWidget {
  id          String  @id @default(cuid())
  dashboardId String
  type        String
  title       String
  dataSource  String
  groupBy     String?
  timeBucket  String?
  filtersJson Json?
  configJson  Json?
  position    Int     @default(0)

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)

  @@index([dashboardId])
}

// v1.69: intake forms — map submissions to tasks in a chosen project.
model IntakeForm {
  id          String   @id @default(cuid())
  teamId      String
  projectId   String
  name        String
  description String?
  // TEAM = authenticated team members (default). PUBLIC = opaque-token URL.
  mode        String   @default("TEAM")
  publicToken String?  @unique
  enabled     Boolean  @default(true)
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  team    Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  project Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator User?             @relation("IntakeFormCreator", fields: [createdById], references: [id], onDelete: SetNull)
  fields  IntakeFormField[]

  @@index([teamId])
  @@index([publicToken])
}

model IntakeFormField {
  id            String  @id @default(cuid())
  formId        String
  label         String
  // Built-in: title | description | priority | dueDate | assignee | labels
  // Custom: customField (requires customFieldId)
  target        String
  customFieldId String?
  required      Boolean @default(false)
  helpText      String?
  position      Int

  form        IntakeForm             @relation(fields: [formId], references: [id], onDelete: Cascade)
  customField CustomFieldDefinition? @relation(fields: [customFieldId], references: [id], onDelete: SetNull)

  @@index([formId])
}

model Attachment {
  id         String   @id @default(cuid())
  taskId     String
  uploaderId String
  // Display name shown in UI; never used to construct filesystem paths.
  filename   String
  // Opaque storage path on disk, generated by the server.
  storageKey String
  mimeType   String
  sizeBytes  Int
  createdAt  DateTime @default(now())
  task       Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  // Cascade — when a user is deleted, their uploaded blobs are removed along
  // with the user account. The on-disk files are NOT cleaned up automatically;
  // a janitor task is the proper home for orphan-blob GC.
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Comment {
  id        String   @id @default(cuid())
  taskId    String
  // authorId nullable + SetNull so a deleted user's comments survive.
  authorId  String?
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  // v1.21: soft-delete. Same shape as Task — null = live; set = in trash.
  deletedAt   DateTime?
  deletedById String?
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  deletedBy User?    @relation("CommentDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  // v1.30: tsvector for full-text search. See Task.searchVector for
  // rationale + lifecycle (managed by raw SQL, never read via Prisma).
  // Unsupported(...) auto-excludes the column from the Prisma client; the
  // SearchService talks to it via $queryRaw only.
  searchVector Unsupported("tsvector")?

  @@index([taskId, createdAt])
  @@index([taskId, deletedAt])
}

model Activity {
  id        String   @id @default(cuid())
  // Phase 3A: taskId is now nullable. Future event types (directory.created,
  // user.provisioned, auth.2fa_enabled, token.created) don't belong to a
  // task; teamId or neither is set instead.
  taskId    String?
  // Denormalized team scope. Filled by logActivity at write time — either
  // explicitly by the caller, or auto-resolved from Task.teamId when only
  // taskId is supplied. Indexed for the team-scoped audit-log query.
  teamId    String?
  // Phase 3A: nullable so system-emitted events (scheduler, SCIM
  // auto-provision) have no human actor. SetNull on user delete preserves
  // the row for audit forensics — the audit log is the one place where
  // "(deleted user) did X" is more useful than dropping the row.
  actorId   String?
  action    String
  meta      Json
  createdAt DateTime @default(now())
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  team      Team?    @relation("TeamActivity", fields: [teamId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@index([teamId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
}

enum WebhookDeliveryStatus {
  PENDING
  DELIVERED
  FAILED
}

// Server-to-server API token. Authenticates as `ownerId`; the token's
// scopes are advisory in Phase 3B (request.user reflects the owner, so
// permission falls out of the owner's GlobalRole + TeamMembership). The
// raw token surfaces ONCE at generate; only sha256(rawToken) persists.
model ApiToken {
  id         String    @id @default(cuid())
  ownerId    String
  name       String
  // First 8 chars of the raw token, shown in the UI to disambiguate
  // multiple tokens (e.g. "th_a1b2c3d4…"). Not security-sensitive.
  prefix     String
  tokenHash  String    @unique
  // Free-form strings — convention is `<resource>:<action>` (e.g.
  // "tasks:read") or "*" for full access.
  scopes     String[]
  expiresAt  DateTime?
  lastUsedAt DateTime?
  revokedAt  DateTime?
  createdAt  DateTime  @default(now())
  owner      User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([ownerId])
}

// Outbound webhook subscription. teamId-scoped so a directory-managed
// team's automations don't leak into another tenant. `secretEnc` is the
// AES-256-GCM ciphertext of the signing secret used for HMAC headers.
model Webhook {
  id        String   @id @default(cuid())
  teamId    String
  name      String
  url       String
  // The HMAC signing secret. Stored encrypted; surfaced once at creation
  // if the caller didn't supply their own.
  secretEnc String
  // Subscribed event types — e.g. ["task.created","comment.added"] or ["*"].
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([teamId])
}

// One row per outbound delivery attempt cluster. The dispatcher polls
// (status=PENDING AND nextAttemptAt<=now) and updates status + attempt
// + nextAttemptAt as it works. Acts as both a delivery log and the queue.
model WebhookDelivery {
  id            String                @id @default(cuid())
  webhookId     String
  eventType     String
  payload       Json
  status        WebhookDeliveryStatus @default(PENDING)
  attempt       Int                   @default(0)
  maxAttempts   Int                   @default(5)
  httpStatus    Int?
  errorMessage  String?
  nextAttemptAt DateTime              @default(now())
  deliveredAt   DateTime?
  createdAt     DateTime              @default(now())
  webhook       Webhook               @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([status, nextAttemptAt])
  @@index([webhookId, createdAt])
}

// v1.62: instance-wide calendar holidays — specific-date off-days distinct
// from recurring weekend weekdays (calendar.weekend InstanceSetting).
// Dates are UTC midnight calendar anchors (same rule as task dueDate).
model Holiday {
  id          String        @id @default(cuid())
  date        DateTime
  name        String
  recurring   Boolean       @default(false)
  source      HolidaySource @default(MANUAL)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdById String?
  createdBy   User?         @relation("HolidayCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([date])
  @@index([date])
}

// Global instance configuration. Key-value store for toggles that apply to
// the whole deployment (e.g. "registration.public", "smtp.from"). Reads +
// writes are restricted to GlobalRole.ADMIN at the route layer. Schema kept
// deliberately loose (Json value) so future settings don't need a migration
// each time; the API layer enforces shape per-key via Zod.
model InstanceSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
  // Audit trail: which admin last touched this key. Nullable so a deleted
  // admin's row doesn't cascade-delete the setting itself.
  updatedBy String?
}

model Notification {
  id        String     @id @default(cuid())
  userId    String
  teamId    String
  type      NotifyType
  payload   Json
  readAt    DateTime?
  createdAt DateTime   @default(now())
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team       @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

// v1.60: no-code automation rules — team-scoped trigger → conditions → actions.
model AutomationRule {
  id             String   @id @default(cuid())
  teamId         String
  name           String
  description    String?
  enabled        Boolean  @default(true)
  triggerType    String
  conditionMatch String   @default("ALL")
  position       Int      @default(0)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  team           Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  conditions     AutomationCondition[]
  actions        AutomationAction[]
  runs           AutomationRun[]

  @@index([teamId, enabled, triggerType])
}

model AutomationCondition {
  id            String         @id @default(cuid())
  ruleId        String
  factType      String
  operator      String
  valueJson     Json?
  customFieldId String?
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationAction {
  id            String         @id @default(cuid())
  ruleId        String
  actionType    String
  valueJson     Json?
  customFieldId String?
  position      Int            @default(0)
  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId])
}

model AutomationRun {
  id          String         @id @default(cuid())
  ruleId      String
  taskId      String
  triggerType String
  status      String
  detail      String?
  createdAt   DateTime       @default(now())
  rule        AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)

  @@index([ruleId, createdAt])
  @@index([taskId])
}
